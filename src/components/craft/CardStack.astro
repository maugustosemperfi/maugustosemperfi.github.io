---
---

<div class="study card-stack-study" data-card-stack>
  <div
    class="stack"
    data-stack
    tabindex="0"
    role="group"
    aria-label="Card stack demo. Press Enter or the arrow keys to send the top card to the back."
  >
    <article class="stack-card" data-card>Design tokens</article>
    <article class="stack-card" data-card>Motion specs</article>
    <article class="stack-card" data-card>Release notes</article>
  </div>
  <p class="study-note">Flick the top card with mouse or touch — or focus the stack and use the arrow keys.</p>
</div>

<script>
  const root = document.querySelector('[data-card-stack]');
  const stack = root?.querySelector('[data-stack]');
  if (!stack) throw new Error('Card stack not found');

  /** Visual order: index 0 is the top card. Rotated on each dismissal. */
  let deck = Array.from(stack.querySelectorAll('[data-card]'));
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const DISMISS_DISTANCE = 90; // px of drag that counts as a deliberate dismiss
  const FLICK_VELOCITY = 0.6; // px/ms of release speed that counts as a flick
  const COMFORT_RANGE = 140; // px of free travel before rubber-band resistance
  const MAX_ROTATION = 9; // deg of card tilt at full comfortable range

  let drag = null; // { card, startX, x, samples }
  let animating = false;

  /* Past COMFORT_RANGE the extra displacement decays, asymptotically capping at 2x. */
  function rubberBand(offset) {
    const magnitude = Math.abs(offset);
    if (magnitude <= COMFORT_RANGE) return offset;
    const excess = magnitude - COMFORT_RANGE;
    return Math.sign(offset) * (COMFORT_RANGE + (excess * COMFORT_RANGE) / (excess + COMFORT_RANGE));
  }

  /* Average pointer velocity (px/ms) over the last ~80ms of movement. */
  function releaseVelocity(samples) {
    const now = performance.now();
    const recent = samples.filter((s) => now - s.t < 80);
    if (recent.length < 2) return 0;
    const first = recent[0];
    const last = recent[recent.length - 1];
    return last.t > first.t ? (last.x - first.x) / (last.t - first.t) : 0;
  }

  function slotTransform(i) {
    return `translateY(${i * 6}px) scale(${1 - i * 0.03})`;
  }

  /* `stagger` is used right after a cycle: the promoted cards settle with a
     springy, staggered re-layer while the dismissed card slips in behind. */
  function layout(stagger = false) {
    deck.forEach((card, i) => {
      card.style.zIndex = String(deck.length - i);
      if (drag && card === drag.card) return;
      const isRecycled = stagger && i === deck.length - 1;
      card.style.transition =
        reduced || !stagger || isRecycled ? 'none' : `transform 550ms var(--spring-settle) ${i * 50}ms`;
      card.style.transform = slotTransform(i);
    });
  }

  function cycleTop(direction, speed = 0, fromX = 0) {
    const card = deck[0];
    if (!card || animating) return;

    if (reduced) {
      deck = [...deck.slice(1), card];
      card.style.opacity = '';
      layout(true);
      return;
    }

    animating = true;
    const exitX = direction * (stack.offsetWidth * 1.6 + 80);
    // A faster flick exits faster: duration follows the remaining distance.
    const remaining = Math.abs(exitX - fromX);
    const duration = speed > 0 ? Math.min(420, Math.max(160, remaining / speed)) : 300;

    card.style.transition = `transform ${duration}ms cubic-bezier(0.2, 0.6, 0.4, 1), opacity ${duration}ms ease-out`;
    card.style.transform = `translateX(${exitX}px) rotate(${direction * 14}deg)`;
    card.style.opacity = '0';

    setTimeout(() => {
      deck = [...deck.slice(1), card];
      card.style.opacity = '';
      layout(true);
      animating = false;
    }, duration + 30);
  }

  function onPointerDown(event) {
    if (animating || drag) return;
    const card = event.currentTarget;
    if (card !== deck[0]) return;
    drag = { card, startX: event.clientX, x: 0, samples: [] };
    card.setPointerCapture(event.pointerId);
    card.style.transition = 'none';
  }

  function onPointerMove(event) {
    if (!drag || event.currentTarget !== drag.card) return;
    drag.x = event.clientX - drag.startX;
    drag.samples.push({ t: performance.now(), x: event.clientX });
    if (drag.samples.length > 8) drag.samples.shift();

    const shown = rubberBand(drag.x);
    const rotation = Math.max(-MAX_ROTATION, Math.min(MAX_ROTATION, (shown / COMFORT_RANGE) * MAX_ROTATION));
    drag.card.style.transform = `translateX(${shown}px) rotate(${rotation}deg)`;
  }

  function onPointerUp() {
    if (!drag) return;
    const { card, x, samples } = drag;
    drag = null;

    const velocity = releaseVelocity(samples);
    if (Math.abs(velocity) >= FLICK_VELOCITY) {
      cycleTop(Math.sign(velocity), Math.abs(velocity), rubberBand(x));
    } else if (Math.abs(x) > DISMISS_DISTANCE) {
      cycleTop(Math.sign(x), 0, rubberBand(x));
    } else {
      card.style.transition = reduced ? 'none' : 'transform 550ms var(--spring-settle)';
      card.style.transform = slotTransform(0);
    }
  }

  deck.forEach((card) => {
    card.addEventListener('pointerdown', onPointerDown);
    card.addEventListener('pointermove', onPointerMove);
    card.addEventListener('pointerup', onPointerUp);
    card.addEventListener('pointercancel', onPointerUp);
  });

  stack.addEventListener('keydown', (event) => {
    const direction = { ArrowRight: 1, ArrowLeft: -1, Enter: 1, ' ': 1 }[event.key];
    if (!direction) return;
    event.preventDefault();
    cycleTop(direction);
  });

  layout();
</script>

<style>
  .card-stack-study {
    /* Damped spring (stiffness 320, damping 22, mass 1) sampled into linear():
       ~8% overshoot, settles within the 550ms window. */
    --spring-settle: linear(
      0, 0.071, 0.234, 0.433, 0.626, 0.792, 0.919, 1.006, 1.058, 1.082, 1.086,
      1.077, 1.061, 1.044, 1.028, 1.014, 1.005, 0.998, 0.994, 0.993, 0.993,
      0.994, 0.995, 0.997, 1
    );
  }

  .stack {
    position: relative;
    width: min(280px, 100%);
    height: 200px;
    margin: 0 auto;
    touch-action: pan-y;
    border-radius: 12px;
  }

  .stack:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 6px;
  }

  .stack-card {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-md);
    color: var(--color-text);
    cursor: grab;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    user-select: none;
    -webkit-user-select: none;
    will-change: transform;
  }

  .stack-card:active {
    cursor: grabbing;
  }

  .study-note {
    margin: var(--space-6) 0 0;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    .stack-card {
      transition: none !important;
    }
  }
</style>
