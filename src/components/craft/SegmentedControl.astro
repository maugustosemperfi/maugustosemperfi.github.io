---
---

<div class="study segmented-control" data-segmented>
  <div class="segment-track" role="radiogroup" aria-label="Segmented control demo">
    <div class="segment-indicator" aria-hidden="true"></div>
    <button type="button" role="radio" aria-checked="true" data-index="0">Day</button>
    <button type="button" role="radio" aria-checked="false" data-index="1">Week</button>
    <button type="button" role="radio" aria-checked="false" data-index="2">Month</button>
  </div>
  <p class="study-output" data-output>Day view selected</p>
</div>

<script>
  const root = document.querySelector('[data-segmented]');
  if (!root) throw new Error('Segmented control root not found');

  const track = root.querySelector('.segment-track');
  const indicator = root.querySelector('.segment-indicator');
  const buttons = Array.from(root.querySelectorAll('button[role="radio"]'));
  const output = root.querySelector('[data-output]');
  const labels = ['Day view selected', 'Week view selected', 'Month view selected'];
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function moveIndicator(index) {
    const btn = buttons[index];
    if (!indicator || !btn) return;
    indicator.style.width = `${btn.offsetWidth}px`;
    indicator.style.transform = `translateX(${btn.offsetLeft}px)`;
  }

  function select(index) {
    buttons.forEach((btn, i) => {
      const selected = i === index;
      btn.setAttribute('aria-checked', String(selected));
      btn.classList.toggle('active', selected);
    });
    if (output) output.textContent = labels[index];
    moveIndicator(index);
  }

  buttons.forEach((btn, index) => {
    btn.addEventListener('click', () => select(index));
    btn.addEventListener('keydown', (e) => {
      let next = index;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (index + 1) % buttons.length;
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (index - 1 + buttons.length) % buttons.length;
      else return;
      e.preventDefault();
      select(next);
      buttons[next].focus();
    });
  });

  select(0);
  window.addEventListener('resize', () => {
    const active = buttons.findIndex((b) => b.classList.contains('active'));
    moveIndicator(active >= 0 ? active : 0);
  });
</script>

<style>
  .segment-track {
    position: relative;
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-elevated);
    padding: 4px;
    gap: 2px;
  }

  .segment-indicator {
    position: absolute;
    top: 4px;
    left: 4px;
    height: calc(100% - 8px);
    border-radius: 999px;
    background: var(--color-accent);
    transition: transform 320ms var(--ease-out-quint), width 320ms var(--ease-out-quint);
    pointer-events: none;
  }

  .segment-track button {
    position: relative;
    z-index: 1;
    min-width: 72px;
    min-height: 44px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    font: inherit;
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0 1rem;
    transition: color 200ms var(--ease-out-quint);
  }

  .segment-track button.active {
    color: var(--color-bg);
  }

  .segment-track button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .study-output {
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    .segment-indicator {
      transition: none;
    }
  }
</style>
