---
/**
 * CraftChapter — one full-width study section: header (title, note, optional
 * "feel" editorial line), the demo stage, and the in-page source panel.
 * Shared by the EN and PT craft pages so the structure can't drift.
 */
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import { splitCraftSource } from '../../lib/craft-source';
import CodePanel from './CodePanel.astro';

interface Props {
  locale: Locale;
  id: string;
  title: string;
  note: string;
  feel?: string;
  source: string;
}

const { locale, id, title, note, feel, source } = Astro.props;
const t = useTranslations(locale);
const sections = splitCraftSource(source);
---

<section class="craft-chapter" id={id}>
  <header class="chapter-header">
    <h2>{title}</h2>
    <p class="chapter-note">{note}</p>
    {feel && <p class="chapter-feel">{feel}</p>}
  </header>

  <div class="chapter-stage">
    <slot />
  </div>

  <CodePanel
    markup={sections.markup}
    script={sections.script}
    style={sections.style}
    panelId={`${id}-code`}
    labelTablist={t('craft.codeTabsLabel')}
    labelBehavior={t('craft.tabBehavior')}
    labelMarkup={t('craft.tabMarkup')}
    labelStyles={t('craft.tabStyles')}
    labelCopy={t('craft.copy')}
    labelCopied={t('craft.copied')}
    labelShowAll={t('craft.showAll')}
    labelCollapse={t('craft.collapse')}
  />
</section>

<style>
  .craft-chapter {
    margin-top: var(--space-16);
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .chapter-header h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-2xl);
  }

  .chapter-note {
    max-width: 62ch;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: 1.55;
  }

  .chapter-feel {
    max-width: 62ch;
    margin: var(--space-4) 0 0;
    padding-left: var(--space-4);
    border-left: 3px solid var(--color-rust);
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .chapter-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 260px;
    margin: var(--space-8) 0 var(--space-6);
    padding: var(--space-8) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-elevated);
  }
</style>
