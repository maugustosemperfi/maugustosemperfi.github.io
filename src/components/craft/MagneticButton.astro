---
---

<div class="study magnetic-study">
  <div class="magnetic-zone" data-magnetic-zone>
    <button type="button" class="magnetic-btn" data-magnetic>
      <span class="magnetic-label">Hover me</span>
    </button>
  </div>
  <p class="study-note">Cursor proximity attraction on pointer devices; press animation on touch.</p>
</div>

<script>
  const zone = document.querySelector('[data-magnetic-zone]');
  const button = zone?.querySelector('[data-magnetic]');
  const label = button?.querySelector('.magnetic-label');
  if (!zone || !button || !label) throw new Error('Magnetic button not found');

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hoverless = window.matchMedia('(hover: none)').matches;

  const RADIUS = 150; // px from the button center where attraction reaches zero
  const PULL = 0.34; // fraction of the cursor offset transferred to the button
  const LABEL_LAG = 0.4; // label trails behind: it keeps ~60% of the button's travel
  const STIFFNESS = 320; // spring constants give zeta ~0.39 -> visible overshoot on release
  const DAMPING = 14;

  const AXES = ['x', 'y', 'scale'];
  const EPSILON = { x: 0.1, y: 0.1, scale: 0.002 };
  const current = { x: 0, y: 0, scale: 1 };
  const velocity = { x: 0, y: 0, scale: 0 };
  const target = { x: 0, y: 0, scale: 1 };
  let lastTime = 0;
  let frame = 0;

  function render() {
    button.style.transform = `translate3d(${current.x}px, ${current.y}px, 0) scale(${current.scale})`;
    label.style.transform = `translate3d(${-current.x * LABEL_LAG}px, ${-current.y * LABEL_LAG}px, 0)`;
  }

  function settled() {
    return AXES.every(
      (axis) =>
        Math.abs(current[axis] - target[axis]) < EPSILON[axis] &&
        Math.abs(velocity[axis]) < EPSILON[axis] * 20,
    );
  }

  function tick(now) {
    const dt = Math.min((now - lastTime) / 1000, 1 / 30);
    lastTime = now;
    for (const axis of AXES) {
      const displacement = current[axis] - target[axis];
      velocity[axis] += (-STIFFNESS * displacement - DAMPING * velocity[axis]) * dt;
      current[axis] += velocity[axis] * dt;
    }
    if (settled()) {
      Object.assign(current, target);
      Object.assign(velocity, { x: 0, y: 0, scale: 0 });
      render();
      frame = 0;
      return;
    }
    render();
    frame = requestAnimationFrame(tick);
  }

  function wake() {
    if (frame) return;
    lastTime = performance.now();
    frame = requestAnimationFrame(tick);
  }

  function press(down) {
    button.classList.toggle('pressed', down);
    if (reduced) return; // press reads through color only — no motion
    target.scale = down ? 0.94 : 1;
    wake();
  }

  button.addEventListener('pointerdown', () => press(true));
  button.addEventListener('pointerup', () => press(false));
  button.addEventListener('pointercancel', () => press(false));
  button.addEventListener('pointerleave', () => press(false));
  button.addEventListener('keydown', (e) => {
    if (e.key === ' ' || e.key === 'Enter') press(true);
  });
  button.addEventListener('keyup', (e) => {
    if (e.key === ' ' || e.key === 'Enter') press(false);
  });

  if (!hoverless && !reduced) {
    zone.addEventListener('pointermove', (event) => {
      const rect = button.getBoundingClientRect();
      // Measure from the rest-position center, not the translated one.
      const dx = event.clientX - (rect.left + rect.width / 2 - current.x);
      const dy = event.clientY - (rect.top + rect.height / 2 - current.y);
      const distance = Math.hypot(dx, dy);
      const t = Math.max(0, 1 - distance / RADIUS);
      const falloff = t * t * (3 - 2 * t); // smoothstep: full pull up close, zero at the radius
      target.x = dx * PULL * falloff;
      target.y = dy * PULL * falloff;
      wake();
    });

    zone.addEventListener('pointerleave', () => {
      target.x = 0;
      target.y = 0;
      wake(); // the spring carries it home with a small overshoot
    });
  }
</script>

<style>
  .magnetic-study {
    text-align: center;
  }

  .magnetic-zone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-16);
  }

  .magnetic-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    min-height: 52px;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    font-size: var(--text-base);
    font-weight: 700;
    will-change: transform;
    transition: background 180ms var(--ease-out-quint), border-color 180ms var(--ease-out-quint);
  }

  .magnetic-label {
    display: inline-block;
    will-change: transform;
  }

  .magnetic-btn:hover {
    border-color: var(--color-accent);
  }

  .magnetic-btn.pressed {
    background: var(--color-chip-bg);
  }

  .magnetic-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .study-note {
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
</style>
