---
import { SITE_TITLE, SOCIAL } from '../consts';
import type { Locale } from '../i18n/ui';
import { localizedPath, useTranslations } from '../i18n/ui';
import CommandPalette from './CommandPalette.astro';
import HeaderLink from './HeaderLink.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'en' ? 'pt' : 'en';
const strippedPath = Astro.url.pathname.replace(/^\/pt/, '') || '/';
const isBlogPost = /^\/blog\/[^/]+\/?$/.test(strippedPath);
const switchPath = isBlogPost
  ? localizedPath('/blog', otherLocale)
  : localizedPath(strippedPath, otherLocale);
---

<header>
  <nav class="site-container">
    <a href={localizedPath('/', locale)} class="logo">{SITE_TITLE}</a>
    <div class="nav-links">
      <HeaderLink href={localizedPath('/', locale)}>{t('nav.home')}</HeaderLink>
      <HeaderLink href={localizedPath('/blog', locale)}>{t('nav.writing')}</HeaderLink>
      <HeaderLink href={localizedPath('/about', locale)}>{t('nav.about')}</HeaderLink>
    </div>
    <div class="header-actions">
      <a href={switchPath} class="lang-switch" aria-label={t('lang.switch')}>
        {locale === 'en' ? 'PT' : 'EN'}
      </a>
      <button type="button" class="icon-btn palette-trigger" data-palette-trigger aria-label={t('nav.search')}>
        <span class="search-hint" aria-hidden="true">⌘K</span>
      </button>
      <button type="button" class="icon-btn theme-toggle" aria-label={t('nav.toggleTheme')}>
        <svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2" />
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          />
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path
            fill="currentColor"
            d="M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5Z"
          />
        </svg>
      </button>
      <a href={SOCIAL.twitter} target="_blank" rel="noopener" aria-label="X / Twitter" class="icon-btn">
        <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
          <path
            fill="currentColor"
            d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
          />
        </svg>
      </a>
      <a href={SOCIAL.github} target="_blank" rel="noopener" aria-label="GitHub" class="icon-btn">
        <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          />
        </svg>
      </a>
    </div>
  </nav>
</header>
<CommandPalette locale={locale} />

<script>
  const toggle = document.querySelector('.theme-toggle');
  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-header-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-4);
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
    margin-left: auto;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .lang-switch {
    min-width: 36px;
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 700;
    text-decoration: none;
    border-radius: 6px;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .lang-switch:hover {
    color: var(--color-accent);
    background: var(--color-header-hover-bg);
    text-decoration: none;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    min-height: 36px;
    color: var(--color-text-secondary);
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    transition: color var(--transition-fast), background var(--transition-fast);
    text-decoration: none;
  }

  .icon-btn:hover {
    color: var(--color-accent);
    background: var(--color-header-hover-bg);
  }

  .palette-trigger .search-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .icon-moon {
    display: none;
  }

  :global([data-theme='dark']) .icon-sun {
    display: none;
  }

  :global([data-theme='dark']) .icon-moon {
    display: block;
  }

  @media (max-width: 640px) {
    nav {
      gap: var(--space-4);
    }

    .nav-links {
      gap: var(--space-4);
    }
  }
</style>
