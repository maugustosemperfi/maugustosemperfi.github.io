---
import { SOCIAL } from '../consts';
import type { Locale } from '../i18n/ui';
import { localizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const pages = [
  { label: t('nav.home'), href: localizedPath('/', locale) },
  { label: t('nav.writing'), href: localizedPath('/blog', locale) },
  { label: t('nav.craft'), href: localizedPath('/craft', locale) },
  { label: t('nav.about'), href: localizedPath('/about', locale) },
  { label: t('nav.colophon'), href: localizedPath('/colophon', locale) },
  { label: t('nav.til'), href: localizedPath('/til', locale) },
];

const email = SOCIAL.email.replace('mailto:', '');
---

<dialog id="command-palette" class="palette" aria-label={t('palette.title')}>
  <div class="palette-inner">
    <div class="palette-search">
      <label for="palette-input" class="sr-only">{t('palette.placeholder')}</label>
      <input
        type="search"
        id="palette-input"
        class="palette-input"
        placeholder={t('palette.placeholder')}
        autocomplete="off"
        spellcheck="false"
        role="combobox"
        aria-expanded="false"
        aria-controls="palette-results"
        aria-autocomplete="list"
      />
      <kbd class="palette-kbd" aria-hidden="true">esc</kbd>
    </div>
    <div id="palette-results" class="palette-results" role="listbox"></div>
  </div>
</dialog>

<script is:inline define:vars={{ pages, email, labels: {
  pages: t('palette.pages'),
  actions: t('palette.actions'),
  search: t('palette.search'),
  noResults: t('palette.noResults'),
  searchUnavailable: t('palette.searchUnavailable'),
  toggleTheme: t('palette.toggleTheme'),
  copyEmail: t('palette.copyEmail'),
  copied: t('palette.copied'),
  openGithub: t('palette.openGithub'),
  openX: t('palette.openX'),
}, social: { github: SOCIAL.github, twitter: SOCIAL.twitter } }}>
  function initCommandPalette() {
    const dialog = document.getElementById('command-palette');
    const input = document.getElementById('palette-input');
    const resultsEl = document.getElementById('palette-results');
    if (!dialog || !input || !resultsEl) return;

    const triggers = document.querySelectorAll('[data-palette-trigger]');
    let pagefind = null;
    let activeIndex = 0;
    let items = [];
    let lastTrigger = null;

    const actions = [
      { id: 'theme', label: labels.toggleTheme, action: 'theme' },
      { id: 'email', label: labels.copyEmail, action: 'email' },
      { id: 'github', label: labels.openGithub, href: social.github },
      { id: 'x', label: labels.openX, href: social.twitter },
    ];

    async function initPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.init();
        return pagefind;
      } catch {
        return null;
      }
    }

    function buildStaticItems() {
      const pageItems = pages.map((p) => ({ ...p, type: 'page', section: labels.pages }));
      const actionItems = actions.map((a) => ({ ...a, type: 'action', section: labels.actions }));
      return [...pageItems, ...actionItems];
    }

    function renderItems(list) {
      items = list;
      activeIndex = 0;
      if (!list.length) {
        resultsEl.innerHTML = '<p class="palette-empty">' + labels.noResults + '</p>';
        return;
      }

      let currentSection = '';
      resultsEl.innerHTML = list
        .map((item, i) => {
          let html = '';
          if (item.section && item.section !== currentSection) {
            currentSection = item.section;
            html += '<p class="palette-section">' + item.section + '</p>';
          }
          const label = item.label || item.title || item.url;
          const meta = item.excerpt
            ? '<span class="palette-excerpt">' + item.excerpt + '</span>'
            : '';
          return (
            html +
            '<button type="button" class="palette-item' +
            (i === 0 ? ' active' : '') +
            '" data-index="' +
            i +
            '" role="option" aria-selected="' +
            (i === 0) +
            '"><span class="palette-item-label">' +
            label +
            '</span>' +
            meta +
            '</button>'
          );
        })
        .join('');
    }

    async function search(query) {
      const staticItems = buildStaticItems();
      if (!query.trim()) {
        renderItems(staticItems);
        return;
      }

      const q = query.toLowerCase();
      const filtered = staticItems.filter((item) => item.label?.toLowerCase().includes(q));
      const pf = await initPagefind();

      if (pf) {
        const searchResult = await pf.debouncedSearch(query);
        if (searchResult?.results?.length) {
          const searchItems = [];
          for (let i = 0; i < Math.min(searchResult.results.length, 8); i++) {
            const data = await searchResult.results[i].data();
            searchItems.push({
              type: 'search',
              section: labels.search,
              label: data.meta?.title || data.url,
              excerpt: data.excerpt,
              href: data.url,
            });
          }
          renderItems([...filtered, ...searchItems]);
          return;
        }
      } else if (query.length > 0) {
        filtered.push({
          type: 'note',
          section: labels.search,
          label: labels.searchUnavailable,
        });
      }

      renderItems(filtered);
    }

    function closePalette() {
      if (!dialog.open) return;
      dialog.close();
      document.body.style.overflow = '';
      input.setAttribute('aria-expanded', 'false');
      if (lastTrigger instanceof HTMLElement) {
        lastTrigger.focus();
      }
    }

    async function executeItem(item) {
      if (!item) return;

      if (item.action === 'theme') {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        closePalette();
        return;
      }

      if (item.action === 'email') {
        try {
          await navigator.clipboard.writeText(email);
          const btn = resultsEl.querySelector('[data-index="' + activeIndex + '"] .palette-item-label');
          if (btn) btn.textContent = labels.copied;
          setTimeout(closePalette, 600);
        } catch {
          window.location.href = 'mailto:' + email;
        }
        return;
      }

      if (item.href) {
        window.location.href = item.href;
      }
    }

    function openPalette(trigger) {
      lastTrigger = trigger instanceof HTMLElement ? trigger : document.querySelector('[data-palette-trigger]');
      if (!dialog.open) {
        dialog.showModal();
      }
      document.body.style.overflow = 'hidden';
      input.value = '';
      input.setAttribute('aria-expanded', 'true');
      renderItems(buildStaticItems());
      requestAnimationFrame(() => input.focus());
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openPalette(event.currentTarget);
      });
    });

    document.addEventListener(
      'keydown',
      (e) => {
        const key = e.key.toLowerCase();

        if ((e.metaKey || e.ctrlKey) && key === 'k') {
          e.preventDefault();
          e.stopImmediatePropagation();
          if (dialog.open) closePalette();
          else openPalette();
          return;
        }

        if (key === 'escape' && dialog.open) {
          e.preventDefault();
          closePalette();
        }
      },
      { capture: true },
    );

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closePalette();
    });

    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
      input.setAttribute('aria-expanded', 'false');
    });

    input.addEventListener('input', () => search(input.value));

    resultsEl.addEventListener('click', (e) => {
      const btn = e.target.closest('.palette-item');
      if (!btn) return;
      const index = Number(btn.getAttribute('data-index'));
      executeItem(items[index]);
    });

    input.addEventListener('keydown', (e) => {
      const btns = resultsEl.querySelectorAll('.palette-item');
      if (!btns.length) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = Math.min(activeIndex + 1, btns.length - 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        executeItem(items[activeIndex]);
        return;
      } else {
        return;
      }

      btns.forEach((btn, i) => {
        btn.classList.toggle('active', i === activeIndex);
        btn.setAttribute('aria-selected', String(i === activeIndex));
      });
      btns[activeIndex]?.scrollIntoView({ block: 'nearest' });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCommandPalette);
  } else {
    initCommandPalette();
  }
</script>

<style>
  .palette {
    position: relative;
    overflow: hidden;
    width: min(560px, calc(100vw - 2rem));
    max-height: min(70vh, 520px);
    margin: auto;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background:
      linear-gradient(135deg, var(--color-panel-grad-a), var(--color-panel-grad-b)),
      var(--color-bg-elevated);
    box-shadow: 0 24px 70px var(--color-panel-shadow);
    color: var(--color-text);
  }

  .palette::before {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, var(--color-panel-grid) 1px, transparent 1px),
      linear-gradient(var(--color-panel-grid) 1px, transparent 1px);
    background-size: 34px 34px;
    content: '';
    pointer-events: none;
  }

  .palette::backdrop {
    background: oklch(20% 0.01 60 / 0.5);
    backdrop-filter: blur(4px);
  }

  .palette-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    max-height: inherit;
  }

  .palette-search {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border-bottom: 1px solid var(--color-signal-divider);
    padding-inline: var(--space-4);
  }

  .palette-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    padding-block: var(--space-4);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .palette-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .palette-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .palette-input:focus-visible {
    outline: none;
  }

  .palette-kbd {
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-chip-bg);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
    padding: 0.28rem 0.45rem;
    text-transform: lowercase;
  }

  .palette-results {
    overflow-y: auto;
    padding: var(--space-2) var(--space-2) var(--space-3);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-strong) transparent;
  }

  .palette-results::-webkit-scrollbar {
    width: 8px;
  }

  .palette-results::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: var(--color-border-strong);
  }

  .palette-results::-webkit-scrollbar-track {
    background: transparent;
  }

  /* innerHTML items lack Astro scope — style via :global under .palette */
  .palette :global(.palette-section) {
    margin: var(--space-3) var(--space-2) var(--space-2);
    color: var(--color-rust);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .palette :global(.palette-section:first-child) {
    margin-top: var(--space-2);
  }

  .palette :global(.palette-item) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    width: 100%;
    min-height: 44px;
    margin: 0;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: var(--leading-snug);
    padding: var(--space-3);
    text-align: left;
    -webkit-appearance: none;
    appearance: none;
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .palette :global(.palette-item:hover),
  .palette :global(.palette-item.active) {
    background: var(--color-header-hover-bg);
  }

  .palette :global(.palette-item:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .palette :global(.palette-item-label) {
    font-weight: 600;
    color: var(--color-text);
  }

  .palette :global(.palette-excerpt) {
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
  }

  .palette :global(.palette-empty) {
    padding: var(--space-4);
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
</style>
