---
import { SOCIAL } from '../consts';
import type { Locale } from '../i18n/ui';
import { localizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const pages = [
  { label: t('nav.home'), href: localizedPath('/', locale) },
  { label: t('nav.writing'), href: localizedPath('/blog', locale) },
  { label: t('nav.craft'), href: localizedPath('/craft', locale) },
  { label: t('nav.about'), href: localizedPath('/about', locale) },
  { label: t('nav.colophon'), href: localizedPath('/colophon', locale) },
  { label: t('nav.til'), href: localizedPath('/til', locale) },
];

const email = SOCIAL.email.replace('mailto:', '');
---

<dialog id="command-palette" class="palette" aria-label={t('palette.title')}>
  <div class="palette-inner">
    <input
      type="search"
      id="palette-input"
      class="palette-input"
      placeholder={t('palette.placeholder')}
      autocomplete="off"
      spellcheck="false"
    />
    <div id="palette-results" class="palette-results" role="listbox"></div>
  </div>
</dialog>

<script define:vars={{ pages, email, locale, labels: {
  pages: t('palette.pages'),
  actions: t('palette.actions'),
  search: t('palette.search'),
  noResults: t('palette.noResults'),
  searchUnavailable: t('palette.searchUnavailable'),
  toggleTheme: t('palette.toggleTheme'),
  copyEmail: t('palette.copyEmail'),
  copied: t('palette.copied'),
  openGithub: t('palette.openGithub'),
  openX: t('palette.openX'),
}, social: { github: SOCIAL.github, twitter: SOCIAL.twitter } }}>
  const dialog = document.getElementById('command-palette');
  const input = document.getElementById('palette-input');
  const resultsEl = document.getElementById('palette-results');
  const triggers = document.querySelectorAll('[data-palette-trigger]');
  let pagefind = null;
  let activeIndex = 0;
  let items = [];

  const actions = [
    { id: 'theme', label: labels.toggleTheme, action: 'theme' },
    { id: 'email', label: labels.copyEmail, action: 'email' },
    { id: 'github', label: labels.openGithub, href: social.github },
    { id: 'x', label: labels.openX, href: social.twitter },
  ];

  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      const module = import.meta.env.DEV
        ? '/pagefind/pagefind.js'
        : '/pagefind/pagefind.js';
      pagefind = await import(/* @vite-ignore */ module);
      await pagefind.init();
      return pagefind;
    } catch {
      return null;
    }
  }

  function buildStaticItems() {
    const pageItems = pages.map((p) => ({ ...p, type: 'page', section: labels.pages }));
    const actionItems = actions.map((a) => ({ ...a, type: 'action', section: labels.actions }));
    return [...pageItems, ...actionItems];
  }

  function renderItems(list) {
    items = list;
    activeIndex = 0;
    if (!list.length) {
      resultsEl.innerHTML = `<p class="palette-empty">${labels.noResults}</p>`;
      return;
    }

    let currentSection = '';
    resultsEl.innerHTML = list
      .map((item, i) => {
        let html = '';
        if (item.section && item.section !== currentSection) {
          currentSection = item.section;
          html += `<p class="palette-section">${item.section}</p>`;
        }
        const label = item.label || item.title || item.url;
        const meta = item.excerpt ? `<span class="palette-excerpt">${item.excerpt}</span>` : '';
        return `${html}<button type="button" class="palette-item${i === 0 ? ' active' : ''}" data-index="${i}" role="option" aria-selected="${i === 0}">
          <span class="palette-item-label">${label}</span>${meta}
        </button>`;
      })
      .join('');
  }

  async function search(query) {
    const staticItems = buildStaticItems();
    if (!query.trim()) {
      renderItems(staticItems);
      return;
    }

    const q = query.toLowerCase();
    const filtered = staticItems.filter((item) => item.label?.toLowerCase().includes(q));
    const pf = await initPagefind();

    if (pf) {
      const searchResult = await pf.debouncedSearch(query);
      if (searchResult?.results?.length) {
        const searchItems = [];
        for (let i = 0; i < Math.min(searchResult.results.length, 8); i++) {
          const data = await searchResult.results[i].data();
          searchItems.push({
            type: 'search',
            section: labels.search,
            label: data.meta?.title || data.url,
            excerpt: data.excerpt,
            href: data.url,
          });
        }
        renderItems([...filtered, ...searchItems]);
        return;
      }
    } else if (query.length > 0) {
      filtered.push({
        type: 'note',
        section: labels.search,
        label: labels.searchUnavailable,
      });
    }

    renderItems(filtered);
  }

  function closePalette() {
    dialog?.close();
    document.body.style.overflow = '';
    const trigger = document.querySelector('[data-palette-trigger]:focus-within') ||
      document.querySelector('[data-palette-trigger]');
    if (trigger instanceof HTMLElement) trigger.focus();
  }

  async function executeItem(item) {
    if (item.action === 'theme') {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      closePalette();
      return;
    }
    if (item.action === 'email') {
      await navigator.clipboard.writeText(email);
      const btn = resultsEl.querySelector(`[data-index="${activeIndex}"] .palette-item-label`);
      if (btn) btn.textContent = labels.copied;
      setTimeout(closePalette, 600);
      return;
    }
    if (item.href) {
      window.location.href = item.href;
    }
  }

  function openPalette() {
    dialog?.showModal();
    document.body.style.overflow = 'hidden';
    input.value = '';
    renderItems(buildStaticItems());
    setTimeout(() => input?.focus(), 50);
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', openPalette);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (dialog?.open) closePalette();
      else openPalette();
    }
  });

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) closePalette();
  });

  dialog?.addEventListener('close', () => {
    document.body.style.overflow = '';
  });

  input?.addEventListener('input', () => search(input.value));

  resultsEl?.addEventListener('click', (e) => {
    const btn = e.target.closest('.palette-item');
    if (!btn) return;
    const index = Number(btn.getAttribute('data-index'));
    executeItem(items[index]);
  });

  input?.addEventListener('keydown', (e) => {
    const btns = resultsEl?.querySelectorAll('.palette-item');
    if (!btns?.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, btns.length - 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      executeItem(items[activeIndex]);
      return;
    } else if (e.key === 'Escape') {
      closePalette();
      return;
    } else {
      return;
    }

    btns.forEach((btn, i) => {
      btn.classList.toggle('active', i === activeIndex);
      btn.setAttribute('aria-selected', String(i === activeIndex));
    });
    btns[activeIndex]?.scrollIntoView({ block: 'nearest' });
  });
</script>

<style>
  .palette {
    width: min(560px, calc(100vw - 2rem));
    max-height: min(70vh, 520px);
    margin: auto;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-lg);
    color: var(--color-text);
  }

  .palette::backdrop {
    background: oklch(20% 0.01 60 / 0.45);
  }

  .palette-inner {
    display: flex;
    flex-direction: column;
    max-height: inherit;
  }

  .palette-input {
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    font: inherit;
    font-size: var(--text-base);
    padding: var(--space-4);
    outline: none;
  }

  .palette-input:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .palette-results {
    overflow-y: auto;
    padding: var(--space-2);
  }

  .palette-section {
    margin: var(--space-2) var(--space-2) var(--space-1);
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .palette-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-1);
    width: 100%;
    min-height: 44px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    padding: var(--space-3);
    text-align: left;
    transition: background var(--transition-fast);
  }

  .palette-item:hover,
  .palette-item.active {
    background: var(--color-header-hover-bg);
  }

  .palette-item-label {
    font-weight: 600;
  }

  .palette-excerpt {
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    line-height: 1.4;
  }

  .palette-empty {
    padding: var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
</style>
