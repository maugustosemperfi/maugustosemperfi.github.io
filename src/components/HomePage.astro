---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portrait from '../assets/marcos.jpg';
import FormattedDate from './FormattedDate.astro';
import MaturityBadge from './MaturityBadge.astro';
import { SITE_DESCRIPTION, SOCIAL } from '../consts';
import type { Locale } from '../i18n/ui';
import { localizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === (locale === 'pt' ? 'pt' : 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = posts.slice(0, 3);

const threads = [
  {
    eyebrow: t('threads.mobile.eyebrow'),
    title: t('threads.mobile.title'),
    copy: t('threads.mobile.copy'),
    tags: ['Flutter', 'Design systems', 'Mobile platform'],
  },
  {
    eyebrow: t('threads.web.eyebrow'),
    title: t('threads.web.title'),
    copy: t('threads.web.copy'),
    tags: ['TypeScript', 'React', 'Next.js', 'Motion'],
  },
  {
    eyebrow: t('threads.agents.eyebrow'),
    title: t('threads.agents.title'),
    copy: t('threads.agents.copy'),
    tags: ['Skills', 'Harnesses', 'opencode', 'Claude Code'],
  },
];

const projects = [
  {
    name: 'Fatura reader',
    type: locale === 'pt' ? 'Produto no ar' : 'Live product',
    href: 'https://fatura-reader.pages.dev/',
    copy:
      locale === 'pt'
        ? 'App client-side para ler PDFs de fatura de cartão, comparar meses e detectar cobranças recorrentes — dados financeiros nunca saem do navegador. O app está no ar e é gratuito; o código permanece privado.'
        : 'A client-side app for parsing Brazilian credit card PDFs, comparing months, and detecting recurring charges — financial data never leaves the browser. The app is live and free; the source stays private.',
    stack: ['React', 'TypeScript', 'PDF parsing'],
  },
  {
    name: 'Acordo',
    type: locale === 'pt' ? 'Produto no ar' : 'Live product',
    href: 'https://acordo.pro/',
    copy:
      locale === 'pt'
        ? 'Ferramenta de propostas para freelancers e pequenos negócios no Brasil: rascunho assistido por IA, links compartilháveis, tracking de abertura e aceite em um clique.'
        : 'A proposal tool for Brazilian freelancers and small businesses: AI-assisted proposal drafting, shareable links, opening tracking, and one-click acceptance.',
    stack: ['Next.js', 'Supabase', 'OpenAI'],
  },
  {
    name: 'cli-dm',
    type: locale === 'pt' ? 'Código aberto' : 'Open source',
    href: 'https://github.com/maugustosemperfi/cli-dm',
    copy:
      locale === 'pt'
        ? 'Tracker de trabalho do Claude Code que lê sessões JSONL, spawna agentes como personagens e mapeia tarefas como um dungeon vivo.'
        : 'A Claude Code work tracker that reads JSONL sessions, spawns agents as characters, turns tasks into monsters, and maps new sessions like a living dungeon.',
    stack: ['TypeScript', 'Agents', 'Visualization'],
  },
  {
    name: locale === 'pt' ? 'Caderno de agentes' : 'Agent notebook',
    type: locale === 'pt' ? 'Escrita' : 'Writing',
    href: localizedPath('/blog/skills-are-not-prompts/', locale),
    copy:
      locale === 'pt'
        ? 'Notas de construir com coding agents: o que pertence a skills, o que precisa de testes, e onde o gosto humano ainda precisa guiar.'
        : 'Notes from building with coding agents: what belongs in skills, what needs tests, and where human taste still has to steer.',
    stack: ['Agents', 'DX', 'Workflow'],
  },
];
---

<main class="home site-container">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy reveal">
      <p class="eyebrow">{t('hero.eyebrow')}</p>
      <h1 id="hero-title">I build systems, tools, and agent workflows that survive contact with real work.</h1>
      <p class="hero-lede">{t('hero.lede')}</p>
      <div class="hero-actions" aria-label="Primary links">
        <a class="button primary" href={localizedPath('/blog', locale)}>{t('hero.readNotes')}</a>
        <a class="button secondary" href={SOCIAL.github}>{t('hero.github')}</a>
        <a class="button ghost" href={SOCIAL.email}>{t('hero.email')}</a>
      </div>
    </div>

    <aside class="profile-panel reveal" aria-label="Profile snapshot">
      <div class="portrait-wrap">
        <Image class="portrait" src={portrait} alt="Marcos Augusto" width={168} height={168} />
      </div>
      <dl class="signal-list">
        <div>
          <dt>{t('hero.signal.current')}</dt>
          <dd>{t('hero.signal.currentValue')}</dd>
        </div>
        <div>
          <dt>{t('hero.signal.always')}</dt>
          <dd>{t('hero.signal.alwaysValue')}</dd>
        </div>
        <div>
          <dt>{t('hero.signal.exploring')}</dt>
          <dd>{t('hero.signal.exploringValue')}</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="mode-lab reveal" aria-labelledby="mode-title">
    <div class="section-kicker">
      <p class="eyebrow">{t('threads.eyebrow')}</p>
      <h2 id="mode-title">{t('threads.title')}</h2>
    </div>
    <div class="thread-grid">
      {
        threads.map((thread) => (
          <article class="thread-card">
            <p class="panel-eyebrow">{thread.eyebrow}</p>
            <h3>{thread.title}</h3>
            <p>{thread.copy}</p>
            <ul class="tag-list" aria-label={`${thread.eyebrow} technologies`}>
              {thread.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="projects reveal" id="projects" aria-labelledby="projects-title">
    <div class="section-kicker">
      <p class="eyebrow">{t('projects.eyebrow')}</p>
      <h2 id="projects-title">{t('projects.title')}</h2>
    </div>
    <p class="project-note">{t('projects.note')}</p>
    <div class="project-grid">
      {
        projects.map((project) => (
          <a class="project-card" href={project.href}>
            <span class="project-type">{project.type}</span>
            <h3>{project.name}</h3>
            <p>{project.copy}</p>
            <ul class="tag-list">
              {project.stack.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </section>

  <section class="writing reveal" aria-labelledby="writing-title">
    <div class="section-kicker">
      <p class="eyebrow">{t('writing.eyebrow')}</p>
      <h2 id="writing-title">{t('writing.title')}</h2>
    </div>
    {
      recent.length === 0 ? (
        <p class="empty">{t('writing.empty')}</p>
      ) : (
        <ol class="post-list">
          {recent.map((post) => (
            <li class="post-item">
              <a href={localizedPath(`/blog/${post.id}/`, locale)} class="post-link">
                <span class="post-title-row">
                  <span class="post-title">{post.data.title}</span>
                  {post.data.maturity && <MaturityBadge maturity={post.data.maturity} locale={locale} />}
                </span>
                <FormattedDate date={post.data.pubDate} />
              </a>
              <p>{post.data.description}</p>
            </li>
          ))}
        </ol>
      )
    }
    <a href={localizedPath('/blog', locale)} class="text-link">{t('writing.readAll')}</a>
  </section>
</main>

<script>
  const revealTargets = document.querySelectorAll('.reveal');

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 },
    );

    revealTargets.forEach((target) => observer.observe(target));
  } else {
    revealTargets.forEach((target) => target.classList.add('is-visible'));
  }
</script>

<style>
  .home {
    padding-block: clamp(2rem, 5vw, 5rem) var(--space-24);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 370px);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    min-height: calc(100svh - 180px);
    padding-bottom: clamp(2rem, 6vw, 4.5rem);
  }

  .eyebrow,
  .panel-eyebrow,
  .project-type {
    margin: 0 0 var(--space-3);
    color: var(--color-rust);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 11ch;
    margin: 0 0 var(--space-6);
    font-size: clamp(3.25rem, 9vw, 7.2rem);
    color: var(--color-hero-heading);
    line-height: 0.88;
    letter-spacing: 0;
  }

  .hero-lede {
    max-width: 56ch;
    margin-bottom: var(--space-8);
    color: var(--color-text-secondary);
    font-size: 1.45rem;
    line-height: 1.45;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.72rem 1.05rem;
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 220ms var(--ease-out-quint),
      background 220ms var(--ease-out-quint),
      border-color 220ms var(--ease-out-quint),
      color 220ms var(--ease-out-quint);
  }

  .button:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .button.primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .button.secondary {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .button.ghost {
    color: var(--color-accent);
  }

  .profile-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background:
      linear-gradient(135deg, var(--color-panel-grad-a), var(--color-panel-grad-b)),
      var(--color-bg-elevated);
    padding: clamp(1.2rem, 3vw, 1.75rem);
    box-shadow: 0 24px 70px var(--color-panel-shadow);
  }

  .profile-panel::before {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, var(--color-panel-grid) 1px, transparent 1px),
      linear-gradient(var(--color-panel-grid) 1px, transparent 1px);
    background-size: 34px 34px;
    content: '';
    mask-image: linear-gradient(180deg, black, transparent 72%);
    pointer-events: none;
  }

  .portrait-wrap {
    position: relative;
    width: 168px;
    margin-bottom: var(--space-8);
  }

  .portrait {
    display: block;
    aspect-ratio: 1;
    border: 8px solid var(--color-portrait-border);
    border-radius: 50%;
    box-shadow: 0 20px 45px var(--color-portrait-shadow);
  }

  .signal-list {
    position: relative;
    display: grid;
    gap: var(--space-4);
    margin: 0;
  }

  .signal-list div {
    border-top: 1px solid var(--color-signal-divider);
    padding-top: var(--space-4);
  }

  .signal-list dt {
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
  }

  .signal-list dd {
    margin: var(--space-1) 0 0;
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .section-kicker {
    max-width: 720px;
    margin-bottom: var(--space-8);
  }

  .section-kicker h2 {
    margin: 0;
    font-size: clamp(2.35rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .mode-lab,
  .projects,
  .writing {
    padding-top: clamp(3rem, 8vw, 6rem);
  }

  .thread-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 900px) {
    .thread-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .thread-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-elevated);
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .thread-card h3 {
    margin: 0 0 var(--space-4);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .thread-card p:not(.panel-eyebrow) {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-chip-bg);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 700;
    line-height: 1;
    padding: 0.52rem 0.7rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  .project-note {
    max-width: 62ch;
    margin: calc(var(--space-8) * -0.45) 0 var(--space-6);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .project-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    padding: var(--space-6);
    text-decoration: none;
    transition:
      transform 240ms var(--ease-out-quint),
      border-color 240ms var(--ease-out-quint),
      box-shadow 240ms var(--ease-out-quint);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-card-hover-border);
    box-shadow: var(--shadow-card);
    text-decoration: none;
  }

  .project-card h3 {
    margin: 0 0 var(--space-4);
    font-size: 2.15rem;
    letter-spacing: 0;
  }

  .project-card p {
    flex: 1;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .writing {
    display: grid;
    grid-template-columns: minmax(240px, 0.45fr) minmax(0, 1fr);
    column-gap: clamp(2rem, 6vw, 5rem);
    row-gap: var(--space-6);
  }

  .writing .section-kicker {
    margin-bottom: 0;
  }

  .post-list {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-item {
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--color-text);
    text-decoration: none;
  }

  .post-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.05;
  }

  .post-link time {
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .post-item p {
    max-width: 62ch;
    margin: var(--space-2) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .text-link {
    grid-column: 2;
    justify-self: start;
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 620ms var(--ease-out-quint),
      transform 620ms var(--ease-out-quint);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .hero,
    .writing {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .hero-lede {
      font-size: 1.25rem;
    }

    .project-card h3 {
      font-size: 1.9rem;
    }

    .profile-panel {
      max-width: 520px;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: 0;
    }

    .text-link {
      grid-column: 1;
    }
  }

  @media (max-width: 560px) {
    .home {
      padding-top: var(--space-8);
    }

    .hero-lede {
      font-size: 1.15rem;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
    }

    .post-link {
      flex-direction: column;
      gap: var(--space-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .button,
    .project-card {
      animation: none;
      transition: none;
    }

    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>
