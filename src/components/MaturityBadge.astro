---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  maturity: 'seedling' | 'budding' | 'evergreen';
  locale?: Locale;
}

const { maturity, locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const tooltips: Record<Props['maturity'], string> = {
  seedling: t('badge.seedling'),
  budding: t('badge.budding'),
  evergreen: t('badge.evergreen'),
};
---

<span class="maturity-badge" title={tooltips[maturity]}>
  {maturity}
</span>

<style>
  .maturity-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-rust);
    border-radius: 999px;
    color: var(--color-rust);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0.28rem 0.55rem;
    text-transform: lowercase;
  }
</style>
