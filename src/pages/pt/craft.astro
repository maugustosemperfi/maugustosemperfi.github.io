---
import BaseHead from '../../components/BaseHead.astro';
import CardStack from '../../components/craft/CardStack.astro';
import CraftChapter from '../../components/craft/CraftChapter.astro';
import MagneticButton from '../../components/craft/MagneticButton.astro';
import SegmentedControl from '../../components/craft/SegmentedControl.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { useTranslations } from '../../i18n/ui';
import cardStackRaw from '../../components/craft/CardStack.astro?raw';
import magneticRaw from '../../components/craft/MagneticButton.astro?raw';
import segmentedRaw from '../../components/craft/SegmentedControl.astro?raw';

const t = useTranslations('pt');

const studies = [
  {
    id: 'segmented-control',
    title: 'Segmented control',
    note: 'Indicador deslizante estilo iOS com motion de mola, arraste para selecionar e navegação por teclado.',
    // TODO-MARCOS: one paragraph in your voice on why this interaction feels right
    feel: '',
    Study: SegmentedControl,
    source: segmentedRaw,
    props: { motionLabel: t('craft.motionLabel') },
  },
  {
    id: 'magnetic-button',
    title: 'Magnetic button',
    note: 'Atração por proximidade do cursor com falloff suave, parallax no rótulo e retorno com mola.',
    // TODO-MARCOS: one paragraph in your voice on why this interaction feels right
    feel: '',
    Study: MagneticButton,
    source: magneticRaw,
  },
  {
    id: 'card-stack',
    title: 'Card stack',
    note: 'Flick sensível à velocidade com resistência elástica, para mouse, touch e teclado.',
    // TODO-MARCOS: one paragraph in your voice on why this interaction feels right
    feel: '',
    Study: CardStack,
    source: cardStackRaw,
  },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={`Craft — Marcos Augusto`}
      description={t('craft.intro')}
      locale="pt"
      alternateLocales={[{ locale: 'en', url: '/craft/' }]}
    />
  </head>
  <body>
    <Header locale="pt" />
    <main class="site-container page-main">
      <div class="section-kicker">
        <p class="eyebrow">{t('craft.eyebrow')}</p>
        <h1>{t('craft.title')}</h1>
        <p class="intro">{t('craft.intro')}</p>
        <p class="source-claim">{t('craft.sourceClaim')}</p>
      </div>

      {
        studies.map(({ id, title, note, feel, Study, source, props }) => (
          <CraftChapter locale="pt" id={id} title={title} note={note} feel={feel} source={source}>
            <Study {...(props ?? {})} />
          </CraftChapter>
        ))
      }
    </main>
    <Footer locale="pt" />

    <style>
      .page-main {
        padding-block: var(--space-8) var(--space-24);
      }

      .eyebrow {
        margin: 0 0 var(--space-3);
        color: var(--color-rust);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .section-kicker h1 {
        margin: 0 0 var(--space-4);
        font-size: clamp(2.35rem, 5vw, 4rem);
        line-height: 0.95;
      }

      .intro {
        max-width: 62ch;
        margin: 0;
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
        line-height: 1.55;
      }

      .source-claim {
        max-width: 62ch;
        margin: var(--space-4) 0 0;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-text-tertiary);
      }
    </style>
  </body>
</html>
