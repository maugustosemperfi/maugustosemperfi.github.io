---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import MaturityBadge from '../../../components/MaturityBadge.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import { useTranslations } from '../../../i18n/ui';

const t = useTranslations('pt');

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === 'pt')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={`${t('blog.title')} — ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
      locale="pt"
      alternateLocales={[{ locale: 'en', url: '/blog/' }]}
    />
    <style>
      .page-main {
        padding-block: var(--space-8) var(--space-24);
      }

      .page-title {
        font-size: var(--text-3xl);
        font-weight: 700;
        margin-bottom: var(--space-4);
      }

      .page-description {
        font-size: var(--text-lg);
        color: var(--color-text-secondary);
        margin-bottom: var(--space-12);
        max-width: 65ch;
      }

      .empty {
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
      }

      .post-list {
        display: grid;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .post-item {
        margin: 0;
        border-top: 1px solid var(--color-border);
        padding-block: var(--space-6);
        transition: transform var(--transition-fast);
      }

      .post-item:hover {
        transform: translateX(4px);
      }

      .post-link {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-4);
        color: var(--color-text);
        text-decoration: none;
      }

      .post-link:hover {
        color: var(--color-accent);
        text-decoration: none;
      }

      .post-title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
      }

      .post-title {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 700;
        line-height: 1.05;
      }

      .post-link time {
        color: var(--color-text-tertiary);
        font-size: var(--text-sm);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
      }

      .post-description {
        max-width: 62ch;
        margin: var(--space-2) 0 0;
        color: var(--color-text-secondary);
        font-size: var(--text-base);
        line-height: var(--leading-normal);
      }
    </style>
  </head>
  <body>
    <Header locale="pt" />
    <main class="site-container page-main">
      <h1 class="page-title">{t('blog.title')}</h1>
      <p class="page-description">{SITE_DESCRIPTION}</p>

      {
        posts.length === 0 ? (
          <p class="empty">{t('blog.ptEmpty')}</p>
        ) : (
          <ol class="post-list">
            {posts.map((post) => (
              <li class="post-item">
                <a href={`/pt/blog/${post.id}/`} class="post-link">
                  <span class="post-title-row">
                    <span class="post-title">{post.data.title}</span>
                    {post.data.maturity && (
                      <MaturityBadge maturity={post.data.maturity} locale="pt" />
                    )}
                  </span>
                  <FormattedDate date={post.data.pubDate} />
                </a>
                <p class="post-description">{post.data.description}</p>
              </li>
            ))}
          </ol>
        )
      }
    </main>
    <Footer locale="pt" />
  </body>
</html>
