---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { useTranslations } from '../../i18n/ui';

const t = useTranslations('pt');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={`Colofão — Marcos Augusto`}
      description="Como este site é construído e mantido."
      locale="pt"
      alternateLocales={[{ locale: 'en', url: '/colophon/' }]}
    />
  </head>
  <body>
    <Header locale="pt" />
    <main class="site-container page-main">
      <article class="prose prose-column">
        <p class="eyebrow">{t('colophon.eyebrow')}</p>
        <h1>{t('colophon.title')}</h1>

        <h2>Stack</h2>
        <p>
          Astro, content collections, GitHub Pages, sem framework no cliente. Busca via Pagefind no
          build. Imagens OG geradas no build com astro-og-canvas.
        </p>

        <h2>Tipografia</h2>
        <p>
          Fraunces (títulos), Instrument Sans (corpo), JetBrains Mono (código) — tudo self-hosted via
          Fontsource.
        </p>

        <h2>Workflow</h2>
        <p>
          Este site é planejado em sessões de trabalho com coding agents: uma passagem de planejamento
          produz um spec, um agente de implementação executa fase a fase, e eu reviso tudo que
          shipa. Os posts do blog são diferentes — esses são escritos inteiramente por mim.
        </p>
      </article>
    </main>
    <Footer locale="pt" />

    <style>
      .page-main {
        padding-block: var(--space-8) var(--space-24);
      }

      .eyebrow {
        margin: 0 0 var(--space-3);
        color: var(--color-rust);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
    </style>
  </body>
</html>
