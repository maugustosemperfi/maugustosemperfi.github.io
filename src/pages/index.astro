---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 3);

const workModes = [
  {
    id: 'systems',
    label: 'Systems',
    eyebrow: 'Day work',
    title: 'Large-scale Clojure systems that need to stay boring.',
    copy:
      'At Nubank I work in the kind of production environment where correctness, operability, and simple mental models matter more than theatrical architecture.',
    tags: ['Clojure', 'Production', 'Financial systems'],
  },
  {
    id: 'agents',
    label: 'Agents',
    eyebrow: 'Current obsession',
    title: 'Agent skills, harnesses, and orchestration for daily engineering.',
    copy:
      'I am building practical agent infrastructure: reusable skills, evaluation harnesses, and workflows that make coding agents more dependable instead of just more flashy.',
    tags: ['Skills', 'Harnesses', 'opencode', 'Claude Code'],
  },
  {
    id: 'tools',
    label: 'Tools',
    eyebrow: 'Personal lab',
    title: 'Small apps that turn personal annoyances into useful interfaces.',
    copy:
      'Finance trackers, receipt readers, home tooling, sim-racing dashboards, and experiments in Flutter, Next.js, TypeScript, and whatever else the problem wants.',
    tags: ['Flutter', 'Next.js', 'TypeScript', 'Telemetry'],
  },
];

const projects = [
  {
    name: 'Fatura reader',
    type: 'Private product tool',
    href: '/about/',
    copy:
      'A client-side app for parsing Brazilian credit card PDFs, comparing months, detecting recurring charges, and keeping sensitive financial data in the browser.',
    stack: ['React', 'TypeScript', 'PDF parsing'],
  },
  {
    name: 'Home controle',
    type: 'Private full-stack app',
    href: '/about/',
    copy:
      'A Flutter and backend system for remote home control, mixing mobile UX, authentication, device commands, deployment, and the very practical edge cases of physical spaces.',
    stack: ['Flutter', 'NestJS', 'IoT'],
  },
  {
    name: 'Portfolio tracker',
    type: 'Private finance system',
    href: '/about/',
    copy:
      'A Brazilian investment tracker built around B3 sync, portfolio summaries, dividend views, backend contracts, and product specs written for agent-assisted implementation.',
    stack: ['Flutter', 'Spring Boot', 'Postgres'],
  },
  {
    name: 'Agent notebook',
    type: 'Public writing',
    href: '/blog/skills-are-not-prompts/',
    copy:
      'Notes from building with coding agents: what belongs in skills, what needs tests, and where human taste still has to steer.',
    stack: ['Agents', 'DX', 'Workflow'],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="home">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy reveal">
          <p class="eyebrow">Marcos Augusto / Brazil / SWE at Nubank</p>
          <h1 id="hero-title">I build systems, tools, and agent workflows that survive contact with real work.</h1>
          <p class="hero-lede">
            Clojure and Flutter in production, TypeScript for personal tools, and a growing lab of
            agent skills, harnesses, and orchestration patterns.
          </p>
          <div class="hero-actions" aria-label="Primary links">
            <a class="button primary" href="#projects">See the work</a>
            <a class="button secondary" href="https://github.com/maugustosemperfi">GitHub</a>
            <a class="button ghost" href="mailto:augustoprofemp@gmail.com">Email</a>
          </div>
        </div>

        <aside class="profile-panel reveal" aria-label="Profile snapshot">
          <div class="portrait-wrap">
            <img
              class="portrait"
              src="https://avatars.githubusercontent.com/u/26628274?v=4"
              alt="Marcos Augusto"
              width="168"
              height="168"
            />
            <span class="status-dot" aria-hidden="true"></span>
          </div>
          <dl class="signal-list">
            <div>
              <dt>Current</dt>
              <dd>Nubank, Clojure, large systems</dd>
            </div>
            <div>
              <dt>Exploring</dt>
              <dd>Agent infrastructure and eval harnesses</dd>
            </div>
            <div>
              <dt>Public and private</dt>
              <dd>37 public repos, plus private tools I can discuss without sharing access</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section class="mode-lab reveal" aria-labelledby="mode-title">
        <div class="section-kicker">
          <p class="eyebrow">What you get here</p>
          <h2 id="mode-title">Three threads, one engineer.</h2>
        </div>
        <div class="mode-shell" data-mode-shell>
          <div class="mode-tabs" role="tablist" aria-label="Work modes">
            {
              workModes.map((mode, index) => (
                <button
                  class:list={['mode-tab', { active: index === 0 }]}
                  type="button"
                  role="tab"
                  aria-selected={index === 0 ? 'true' : 'false'}
                  aria-controls={`mode-${mode.id}`}
                  id={`tab-${mode.id}`}
                  data-mode-tab={mode.id}
                >
                  {mode.label}
                </button>
              ))
            }
          </div>
          <div class="mode-panels">
            {
              workModes.map((mode, index) => (
                <article
                  class:list={['mode-panel', { active: index === 0 }]}
                  id={`mode-${mode.id}`}
                  role="tabpanel"
                  aria-labelledby={`tab-${mode.id}`}
                  data-mode-panel={mode.id}
                  hidden={index !== 0}
                >
                  <p class="panel-eyebrow">{mode.eyebrow}</p>
                  <h3>{mode.title}</h3>
                  <p>{mode.copy}</p>
                  <ul class="tag-list" aria-label={`${mode.label} technologies`}>
                    {mode.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="projects reveal" id="projects" aria-labelledby="projects-title">
        <div class="section-kicker">
          <p class="eyebrow">Selected work</p>
          <h2 id="projects-title">Artifacts with a real problem behind them.</h2>
        </div>
        <p class="project-note">
          This is not a complete repo list. Some of the strongest examples are private, so I describe
          the product shape and engineering tradeoffs instead of linking to source access. Experiments
          like fechar-negocio still matter, but these are the clearer signals.
        </p>
        <div class="project-grid">
          {
            projects.map((project) => (
              <a class="project-card" href={project.href}>
                <span class="project-type">{project.type}</span>
                <h3>{project.name}</h3>
                <p>{project.copy}</p>
                <ul class="tag-list">
                  {project.stack.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </a>
            ))
          }
        </div>
      </section>

      <section class="writing reveal" aria-labelledby="writing-title">
        <div class="section-kicker">
          <p class="eyebrow">Recent writing</p>
          <h2 id="writing-title">The lab notebook.</h2>
        </div>
        {
          recent.length === 0 ? (
            <p class="empty">No posts yet. The first one is on its way.</p>
          ) : (
            <ol class="post-list">
              {recent.map((post) => (
                <li class="post-item">
                  <a href={`/blog/${post.id}/`} class="post-link">
                    <span class="post-title">{post.data.title}</span>
                    <FormattedDate date={post.data.pubDate} />
                  </a>
                  <p>{post.data.description}</p>
                </li>
              ))}
            </ol>
          )
        }
        <a href="/blog" class="text-link">Read all notes</a>
      </section>
    </main>
    <Footer />

    <script>
      const shell = document.querySelector('[data-mode-shell]');
      const tabs = Array.from(document.querySelectorAll('[data-mode-tab]'));
      const panels = Array.from(document.querySelectorAll('[data-mode-panel]'));

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const mode = tab.getAttribute('data-mode-tab');

          tabs.forEach((item) => {
            const selected = item === tab;
            item.classList.toggle('active', selected);
            item.setAttribute('aria-selected', String(selected));
          });

          panels.forEach((panel) => {
            const selected = panel.getAttribute('data-mode-panel') === mode;
            panel.classList.toggle('active', selected);
            panel.toggleAttribute('hidden', !selected);
          });

          shell?.setAttribute('data-active-mode', mode ?? '');
        });
      });

      const revealTargets = document.querySelectorAll('.reveal');

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.18 },
        );

        revealTargets.forEach((target) => observer.observe(target));
      } else {
        revealTargets.forEach((target) => target.classList.add('is-visible'));
      }
    </script>

    <style>
      .home {
        max-width: 1180px;
        padding: clamp(2rem, 5vw, 5rem) var(--space-4) var(--space-24);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 370px);
        gap: clamp(2rem, 6vw, 5rem);
        align-items: center;
        min-height: calc(100svh - 180px);
        padding-bottom: clamp(2rem, 6vw, 4.5rem);
      }

      .eyebrow,
      .panel-eyebrow,
      .project-type {
        margin: 0 0 var(--space-3);
        color: var(--color-rust);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .hero h1 {
        max-width: 11ch;
        margin: 0 0 var(--space-6);
        font-size: 7.2rem;
        color: oklch(34% 0.012 60);
        line-height: 0.88;
        letter-spacing: 0;
      }

      .hero-lede {
        max-width: 56ch;
        margin-bottom: var(--space-8);
        color: var(--color-text-secondary);
        font-size: 1.45rem;
        line-height: 1.45;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
      }

      .button {
        display: inline-flex;
        min-height: 44px;
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.72rem 1.05rem;
        font-size: var(--text-sm);
        font-weight: 700;
        text-decoration: none;
        transition:
          transform 220ms var(--ease-out-quint),
          background 220ms var(--ease-out-quint),
          border-color 220ms var(--ease-out-quint),
          color 220ms var(--ease-out-quint);
      }

      .button:hover {
        transform: translateY(-2px);
        text-decoration: none;
      }

      .button.primary {
        background: var(--color-text);
        color: var(--color-bg);
      }

      .button.secondary {
        border-color: var(--color-border-strong);
        color: var(--color-text);
      }

      .button.ghost {
        color: var(--color-accent);
      }

      .profile-panel {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background:
          linear-gradient(135deg, oklch(98% 0.015 85 / 0.94), oklch(91% 0.04 170 / 0.78)),
          var(--color-bg-elevated);
        padding: clamp(1.2rem, 3vw, 1.75rem);
        box-shadow: 0 24px 70px oklch(22% 0.03 80 / 0.16);
      }

      .profile-panel::before {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(90deg, oklch(30% 0.02 80 / 0.07) 1px, transparent 1px),
          linear-gradient(oklch(30% 0.02 80 / 0.07) 1px, transparent 1px);
        background-size: 34px 34px;
        content: '';
        mask-image: linear-gradient(180deg, black, transparent 72%);
        pointer-events: none;
      }

      .portrait-wrap {
        position: relative;
        width: 168px;
        margin-bottom: var(--space-8);
      }

      .portrait {
        display: block;
        aspect-ratio: 1;
        border: 8px solid oklch(99% 0.005 80 / 0.86);
        border-radius: 50%;
        box-shadow: 0 20px 45px oklch(25% 0.03 80 / 0.18);
      }

      .status-dot {
        position: absolute;
        right: 14px;
        bottom: 16px;
        width: 18px;
        height: 18px;
        border: 4px solid var(--color-bg);
        border-radius: 999px;
        background: var(--color-leaf);
        animation: pulse 2200ms var(--ease-out-quint) infinite;
      }

      .signal-list {
        position: relative;
        display: grid;
        gap: var(--space-4);
        margin: 0;
      }

      .signal-list div {
        border-top: 1px solid oklch(78% 0.025 85 / 0.72);
        padding-top: var(--space-4);
      }

      .signal-list dt {
        color: var(--color-text-tertiary);
        font-size: var(--text-xs);
        font-weight: 700;
        text-transform: uppercase;
      }

      .signal-list dd {
        margin: var(--space-1) 0 0;
        color: var(--color-text);
        font-size: var(--text-sm);
        line-height: 1.5;
      }

      .section-kicker {
        max-width: 720px;
        margin-bottom: var(--space-8);
      }

      .section-kicker h2 {
        margin: 0;
        font-size: 4rem;
        line-height: 0.95;
        letter-spacing: 0;
      }

      .mode-lab,
      .projects,
      .writing {
        padding-top: clamp(3rem, 8vw, 6rem);
      }

      .mode-shell {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        gap: var(--space-6);
        align-items: stretch;
      }

      .mode-tabs {
        display: grid;
        gap: var(--space-2);
        align-content: start;
      }

      .mode-tab {
        min-height: 48px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: transparent;
        color: var(--color-text-secondary);
        cursor: pointer;
        font: inherit;
        font-weight: 700;
        text-align: left;
        padding: 0 var(--space-4);
        transition:
          transform 180ms var(--ease-out-quint),
          background 180ms var(--ease-out-quint),
          color 180ms var(--ease-out-quint),
          border-color 180ms var(--ease-out-quint);
      }

      .mode-tab:hover,
      .mode-tab.active {
        transform: translateX(4px);
        border-color: oklch(58% 0.09 168);
        background: oklch(92% 0.04 168 / 0.6);
        color: var(--color-text);
      }

      .mode-panels {
        min-height: 330px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-bg-elevated);
      }

      .mode-panel {
        padding: clamp(1.5rem, 4vw, 3rem);
        animation: panelIn 360ms var(--ease-out-quint);
      }

      .mode-panel h3 {
        max-width: 16ch;
        margin: 0 0 var(--space-4);
        font-size: 4.25rem;
        line-height: 0.95;
        letter-spacing: 0;
      }

      .mode-panel p:not(.panel-eyebrow) {
        max-width: 68ch;
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
        line-height: 1.55;
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin: var(--space-6) 0 0;
        padding: 0;
        list-style: none;
      }

      .tag-list li {
        margin: 0;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: oklch(99% 0.01 80 / 0.72);
        color: var(--color-text-secondary);
        font-size: var(--text-xs);
        font-weight: 700;
        line-height: 1;
        padding: 0.52rem 0.7rem;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: var(--space-4);
      }

      .project-note {
        max-width: 62ch;
        margin: calc(var(--space-8) * -0.45) 0 var(--space-6);
        color: var(--color-text-secondary);
        font-size: var(--text-sm);
        line-height: 1.65;
      }

      .project-card {
        display: flex;
        min-height: 360px;
        flex-direction: column;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-bg-elevated);
        color: var(--color-text);
        padding: var(--space-6);
        text-decoration: none;
        transition:
          transform 240ms var(--ease-out-quint),
          border-color 240ms var(--ease-out-quint),
          box-shadow 240ms var(--ease-out-quint);
      }

      .project-card:hover {
        transform: translateY(-8px);
        border-color: oklch(60% 0.1 30);
        box-shadow: 0 24px 65px oklch(25% 0.03 80 / 0.13);
        text-decoration: none;
      }

      .project-card h3 {
        margin: 0 0 var(--space-4);
        font-size: 2.15rem;
        letter-spacing: 0;
      }

      .project-card p {
        flex: 1;
        color: var(--color-text-secondary);
        font-size: var(--text-sm);
        line-height: 1.65;
      }

      .writing {
        display: grid;
        grid-template-columns: minmax(240px, 0.45fr) minmax(0, 1fr);
        column-gap: clamp(2rem, 6vw, 5rem);
        row-gap: var(--space-6);
      }

      .writing .section-kicker {
        margin-bottom: 0;
      }

      .post-list {
        display: grid;
        gap: var(--space-4);
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .post-item {
        margin: 0;
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-4);
      }

      .post-link {
        display: flex;
        justify-content: space-between;
        gap: var(--space-4);
        color: var(--color-text);
        text-decoration: none;
      }

      .post-link:hover {
        color: var(--color-rust);
        text-decoration: none;
      }

      .post-title {
        font-family: var(--font-heading);
        font-size: var(--text-xl);
        font-weight: 700;
        line-height: 1.05;
      }

      .post-link time {
        color: var(--color-text-tertiary);
        font-size: var(--text-xs);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
      }

      .post-item p {
        max-width: 62ch;
        margin: var(--space-2) 0 0;
        color: var(--color-text-secondary);
        font-size: var(--text-sm);
      }

      .text-link {
        grid-column: 2;
        justify-self: start;
        color: var(--color-accent);
        font-size: var(--text-sm);
        font-weight: 700;
      }

      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 620ms var(--ease-out-quint),
          transform 620ms var(--ease-out-quint);
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      @keyframes panelIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes pulse {
        0%,
        100% {
          transform: scale(1);
          box-shadow: 0 0 0 0 oklch(62% 0.16 145 / 0.26);
        }

        50% {
          transform: scale(1.08);
          box-shadow: 0 0 0 10px oklch(62% 0.16 145 / 0);
        }
      }

      @media (max-width: 900px) {
        .hero,
        .writing {
          grid-template-columns: 1fr;
        }

        .hero {
          min-height: auto;
        }

        .hero h1 {
          max-width: 12ch;
          font-size: 5rem;
        }

        .hero-lede {
          font-size: 1.25rem;
        }

        .section-kicker h2,
        .mode-panel h3 {
          font-size: 3rem;
        }

        .project-card h3 {
          font-size: 1.9rem;
        }

        .profile-panel {
          max-width: 520px;
        }

        .mode-shell {
          grid-template-columns: 1fr;
        }

        .mode-tabs {
          display: flex;
          overflow-x: auto;
          padding-bottom: var(--space-2);
        }

        .mode-tab {
          min-width: 150px;
        }

        .mode-tab:hover,
        .mode-tab.active {
          transform: translateY(-2px);
        }

        .project-grid {
          grid-template-columns: 1fr;
        }

        .project-card {
          min-height: 0;
        }

        .text-link {
          grid-column: 1;
        }
      }

      @media (max-width: 560px) {
        .home {
          padding-top: var(--space-8);
        }

        .hero h1 {
          font-size: 3.25rem;
        }

        .hero-lede {
          font-size: 1.15rem;
        }

        .section-kicker h2,
        .mode-panel h3 {
          font-size: 2.35rem;
        }

        .hero-actions {
          align-items: stretch;
          flex-direction: column;
        }

        .button {
          width: 100%;
        }

        .post-link {
          flex-direction: column;
          gap: var(--space-1);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal,
        .mode-panel,
        .status-dot,
        .button,
        .mode-tab,
        .project-card {
          animation: none;
          transition: none;
        }

        .reveal {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </body>
</html>
