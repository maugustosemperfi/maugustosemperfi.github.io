---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../i18n/ui';

const t = useTranslations('en');

let entries: Awaited<ReturnType<typeof getCollection<'til'>>> = [];
try {
  entries = (await getCollection('til')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
} catch {
  entries = [];
}

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const grouped = rendered.reduce<Record<string, typeof rendered>>((acc, item) => {
  const key = item.entry.data.pubDate.toLocaleString('en', { year: 'numeric', month: 'long' });
  acc[key] ??= [];
  acc[key].push(item);
  return acc;
}, {});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`TIL — Marcos Augusto`}
      description="Today I learned — short notes on things I pick up along the way."
      alternateLocales={[{ locale: 'pt', url: '/pt/til/' }]}
    />
  </head>
  <body>
    <Header />
    <main class="site-container page-main">
      <div class="section-kicker">
        <p class="eyebrow">{t('til.eyebrow')}</p>
        <h1>{t('til.title')}</h1>
      </div>

      {
        rendered.length === 0 ? (
          <p class="empty">{t('til.empty')}</p>
        ) : (
          Object.entries(grouped).map(([month, monthEntries]) => (
            <section class="til-month">
              <h2>{month}</h2>
              <ul>
                {monthEntries.map(({ entry, Content }) => (
                  <li>
                    <time datetime={entry.data.pubDate.toISOString()}>
                      <FormattedDate date={entry.data.pubDate} />
                    </time>
                    <div class="til-body">
                      <strong>{entry.data.title}</strong>
                      <Content />
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          ))
        )
      }
    </main>
    <Footer />

    <style>
      .page-main {
        padding-block: var(--space-8) var(--space-24);
        max-width: var(--prose-max);
        margin-inline: auto;
      }

      .eyebrow {
        margin: 0 0 var(--space-3);
        color: var(--color-rust);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .section-kicker h1 {
        margin: 0 0 var(--space-8);
        font-size: clamp(2rem, 4vw, 3rem);
      }

      .empty {
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
      }

      .til-month {
        margin-bottom: var(--space-12);
      }

      .til-month h2 {
        margin: 0 0 var(--space-4);
        font-size: var(--text-lg);
        color: var(--color-text-secondary);
      }

      .til-month ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .til-month li {
        display: grid;
        grid-template-columns: 7rem 1fr;
        gap: var(--space-4);
        padding-block: var(--space-4);
        border-top: 1px solid var(--color-border);
      }

      .til-month time {
        color: var(--color-text-tertiary);
        font-size: var(--text-xs);
        font-variant-numeric: tabular-nums;
      }

      .til-body :global(p) {
        margin: var(--space-1) 0 0;
        color: var(--color-text-secondary);
        font-size: var(--text-sm);
        line-height: 1.6;
      }

      @media (max-width: 560px) {
        .til-month li {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
