---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import portrait from '../assets/marcos.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MaturityBadge from '../components/MaturityBadge.astro';
import { SOCIAL } from '../consts';
import { buildBlogPostingJsonLd } from '../lib/jsonld';
import { useTranslations } from '../i18n/ui';

interface Props extends CollectionEntry<'blog'>['data'] {
  slug: string;
  readingTime: number;
  locale?: 'en' | 'pt';
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  maturity,
  slug,
  readingTime,
  locale = 'en',
} = Astro.props;

const t = useTranslations(locale);
const ogImage = `/og/blog/${slug}.png`;
const postUrl = new URL(`/blog/${slug}/`, Astro.site).toString();

const jsonLd = buildBlogPostingJsonLd({
  title,
  description,
  url: postUrl,
  image: new URL(ogImage, Astro.site).toString(),
  pubDate,
  updatedDate,
});
---

<html lang={locale === 'pt' ? 'pt-BR' : 'en'}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImage}
      type="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
      locale={locale}
      jsonLd={jsonLd}
    />
  </head>

  <body>
    <Header locale={locale} />
    <main class="site-container page-main">
      <article>
        {
          heroImage && (
            <div class="hero-image prose-column">
              <Image width={1020} height={510} src={heroImage} alt="" />
            </div>
          )
        }
        <div class="prose prose-column">
          <header class="post-header">
            <p class="post-eyebrow">
              <FormattedDate date={pubDate} />
              <span aria-hidden="true"> · </span>
              {readingTime} min read
              {updatedDate && (
                <>
                  <span aria-hidden="true"> · </span>
                  {t('blog.lastTended')} <FormattedDate date={updatedDate} />
                </>
              )}
              {maturity && (
                <>
                  <span aria-hidden="true"> · </span>
                  <MaturityBadge maturity={maturity} locale={locale} />
                </>
              )}
            </p>
            <h1>{title}</h1>
            <p class="post-lede">{description}</p>
          </header>
          <slot />
          <footer class="post-footer">
            <div class="post-footer-nav">
              <a href={locale === 'pt' ? '/pt/blog/' : '/blog/'}>{t('blog.allNotes')}</a>
              <a href="/rss.xml">RSS</a>
            </div>
            <aside class="author-card">
              <Image class="author-avatar" src={portrait} alt="Marcos Augusto" width={64} height={64} />
              <div>
                <p class="author-name">Marcos Augusto</p>
                <p class="author-line">{t('blog.authorLine')}</p>
                <p class="author-links">
                  <a href={locale === 'pt' ? '/pt/about/' : '/about/'}>About</a>
                  <a href={SOCIAL.github}>GitHub</a>
                  <a href={SOCIAL.twitter}>X</a>
                </p>
              </div>
            </aside>
          </footer>
        </div>
      </article>
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style>
  .page-main {
    padding-block: var(--space-8) var(--space-24);
  }

  .hero-image {
    margin-bottom: var(--space-12);
  }

  .hero-image :global(img) {
    display: block;
    width: 100%;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
  }

  .post-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .post-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
    margin: 0 0 var(--space-4);
    color: var(--color-rust);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-header h1 {
    margin: 0 0 var(--space-4);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.02;
  }

  .post-lede {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }

  .post-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-footer-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .post-footer-nav a {
    text-decoration: none;
  }

  .author-card {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-elevated);
    padding: var(--space-4);
  }

  .author-avatar {
    flex-shrink: 0;
    border-radius: 50%;
    border: 3px solid var(--color-portrait-border);
  }

  .author-name {
    margin: 0 0 var(--space-1);
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .author-line {
    margin: 0 0 var(--space-2);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .author-links {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .author-links a {
    margin-right: var(--space-3);
    text-decoration: none;
  }
</style>
